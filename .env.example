# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Instagram / Facebook Graph API ───────────────────────────────────────────
# Your Instagram Business Account numeric ID
INSTAGRAM_USER_ID=123456789012345
# Long-lived Page Access Token with instagram_basic, instagram_content_publish,
# pages_read_engagement permissions
FACEBOOK_ACCESS_TOKEN=EAA...

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret
